{
  "name": "@markusvankempen/slack-wxo-mcp-gateway",
  "version": "1.0.0",
  "description": "Slack ↔ watsonx Orchestrate MCP gateway by Markus van Kempen — multi-channel Slack→WxO routing, background poller, admin dashboard, IBM Code Engine + local ngrok. Streamable HTTP /mcp for watsonx Orchestrate, Cursor, Claude, and Copilot.",
  "mcpName": "io.github.markusvankempen/slack-wxo-mcp-gateway",
