  "bin": {
    "slack-wxo-mcp-gateway": "bin/slack-wxo-mcp-gateway.js"
  },
  "scripts": {
    "start": "node bin/slack-wxo-mcp-gateway.js",
    "prepublishOnly": "node -e \"require('fs').accessSync('bin/slack-wxo-mcp-gateway.js')\"",
    "github:metadata": "bash scripts/apply-github-metadata.sh",
    "sync:public": "bash scripts/sync-public-repo.sh"
  },
