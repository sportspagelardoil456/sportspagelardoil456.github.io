    }
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/markusvankempen/slack-wxo-mcp-gateway.git"
  },
  "homepage": "https://markusvankempen.github.io/",
  "bugs": {
    "url": "https://github.com/markusvankempen/slack-wxo-mcp-gateway/issues",
    "email": "markus.van.kempen@gmail.com"
  },
  "publishConfig": {
    "access": "public"
  }
}
